# Augment Gateway 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改配置
# 纯环境变量配置，无需config.yaml文件

# ===========================================
# 服务器配置
# ===========================================
# 服务器主机地址
SERVER_HOST=0.0.0.0
# 服务器端口
SERVER_PORT=8080
# 运行模式: debug, release, test
SERVER_MODE=debug

# ===========================================
# MySQL数据库配置
# ===========================================
# MySQL主机地址
MYSQL_HOST=localhost
# MySQL端口
MYSQL_PORT=3306
# MySQL用户名
MYSQL_USERNAME=root
# MySQL密码
MYSQL_PASSWORD=your_password
# 数据库名
MYSQL_DATABASE=augment_gateway

# ===========================================
# Redis配置
# ===========================================
# Redis主机地址
REDIS_HOST=localhost
# Redis端口
REDIS_PORT=6379
# Redis密码（如果有）
REDIS_PASSWORD=
# Redis数据库号
REDIS_DB=1

# ===========================================
# 默认管理员配置
# ===========================================
# 管理员用户名（首次启动时创建）
ADMIN_USERNAME=admin
# 管理员密码（首次启动时创建，请修改为强密码）
ADMIN_PASSWORD=admin123
# 管理员邮箱（可选）
ADMIN_EMAIL=

# ===========================================
# JWT认证配置
# ===========================================
# JWT签名密钥（生产环境必须修改为随机字符串）
JWT_SECRET=change-me-to-a-random-secret
# JWT访问令牌过期时间（秒，默认24小时）
JWT_EXPIRES_IN=86400
# JWT刷新令牌过期时间（秒，默认7天）
JWT_REFRESH_EXPIRES_IN=604800

# ===========================================
# 代理配置
# ===========================================
# 是否禁用转发服务（维护模式）
# true: 禁用转发服务，所有代理请求返回401错误
# false: 正常运行转发服务 (默认)
FORWARD_DISABLED=false

# ===========================================
# 日志配置
# ===========================================
# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===========================================
# /get-models 接口配置
# ===========================================
# 是否启用 /get-models 接口数据修改功能
# true: 启用数据修改，会自动修改 feature_flags 字段并添加 Claude Opus 4.1 模型
# false: 禁用数据修改，直接返回原始响应数据 (默认)
ENABLE_MODELS_MODIFICATION=false

# ===========================================
# /subscription-info 接口配置
# ===========================================
# 是否启用 /subscription-info 接口数据修改功能
# true: 启用数据修改，会自动将所有 display_info 字段替换为 null (默认)
# false: 禁用数据修改，直接返回原始响应数据
ENABLE_SUBSCRIPTION_INFO_MODIFICATION=true

# ===========================================
# 用户认证配置
# ===========================================
# 密码最小长度
USER_AUTH_PASSWORD_MIN_LENGTH=6
# 密码最大长度
USER_AUTH_PASSWORD_MAX_LENGTH=32

# ===========================================
# 前端配置
# ===========================================
# 前端访问URL（用于OAuth登录链接跳转等）
FRONTEND_URL=

# ===========================================
# Telegram通知配置
# ===========================================
# Telegram机器人Token
TELEGRAM_BOT_TOKEN=
# Telegram群组ID
TELEGRAM_CHAT_ID=
# 是否启用Telegram通知
TELEGRAM_ENABLED=false

# ===========================================
# Cloudflare Turnstile配置
# ===========================================
# Turnstile私钥
TURNSTILE_SECRET_KEY=
# 是否启用Turnstile验证
TURNSTILE_ENABLED=false

# ===========================================
# User-Agent配置
# ===========================================
# 是否启用自定义User-Agent功能（默认: false）
ENABLE_CUSTOM_USER_AGENT=false
# 自定义User-Agent值
SUBSCRIPTION_USER_AGENT=

# ===========================================
# VSCode Augment 版本检测配置
# ===========================================
# 是否启用版本检测功能（默认: true）
ENABLE_VERSION_CHECK=true
# 最低支持的 VSCode Augment 版本号（默认: 0.594.0）
MIN_VSCODE_AUGMENT_VERSION=0.594.0

# ===========================================
# 批量导入TOKEN鉴权
# ===========================================
# 批量导入TOKEN接口的鉴权令牌（可选，留空则不验证）
BATCH_IMPORT_AUTH_TOKEN=